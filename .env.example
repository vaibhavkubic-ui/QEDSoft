# Copy this file to .env and fill in your values.
# Never commit .env — only .env.example is committed to git.

# GWDG Academic Cloud AI — https://docs.hpc.gwdg.de/services/chat-ai/models/index.html
CHAT_AI_API_KEY=your_api_key_here
CHAT_AI_ENDPOINT=https://chat-ai.academiccloud.de/v1

# Optional: override the default model
# CHAT_AI_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct
